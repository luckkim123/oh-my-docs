{
  "name": "oh-my-docs",
  "description": "Multi-agent orchestration harness specialized for document work (pptx/docx/xlsx/hwpx)",
  "author": { "name": "kimseungmin" },
  "license": "MIT",
  "keywords": ["claude-code", "plugin", "documents", "pptx", "docx", "xlsx", "orchestration", "multi-agent"],
  "skills": [
    "./skills/docs-intake/",
    "./skills/docs-standardize/",
    "./skills/docs-plan/",
    "./skills/docs-build/",
    "./skills/docs-inspect/",
    "./skills/docs-verify/",
    "./skills/docs-convert/",
    "./skills/docs-revise/",
    "./skills/docs-translate/",
    "./skills/docs-pilot/",
    "./skills/docs-learn/",
    "./skills/docs-pdf/"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/route_emit.py"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/docs_verify_emit.py"]
          }
        ]
      }
    ]
  }
}
